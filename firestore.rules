rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email == 'adrian90.2y@gmail.com';
    }
    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }
    function hasUserDoc() {
      return signedIn() && exists(userPath(request.auth.uid));
    }
    function userDoc() {
      return get(userPath(request.auth.uid));
    }
    function isActiveUser() {
      return isBootstrapAdmin() || (
        hasUserDoc()
        && userDoc().data.active != false
        && userDoc().data.deleted != true
      );
    }
    function isAdmin() {
      return isBootstrapAdmin() || (
        isActiveUser()
        && userDoc().data.role == 'admin'
      );
    }
    function isAllowedEmail() {
      return signedIn()
        && exists(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email))
        && get(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email)).data.active != false;
    }

    match /allowedEmails/{email} {
      allow read: if isAdmin() || (signedIn() && request.auth.token.email == email);
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid && isActiveUser());
      allow create: if signedIn() && request.auth.uid == uid && (isBootstrapAdmin() || isAllowedEmail());
      allow update: if isAdmin() || (signedIn() && request.auth.uid == uid && isActiveUser());
      allow delete: if isAdmin();
    }

    match /inventory/{productId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }

    match /counts/{productId} {
      allow read: if isActiveUser();
      allow create, update: if isAdmin() || (
        isActiveUser()
        && request.resource.data.labKey is string
        && exists(/databases/$(database)/documents/labLocks/$(request.resource.data.labKey))
        && get(/databases/$(database)/documents/labLocks/$(request.resource.data.labKey)).data.lockedByUid == request.auth.uid
        && get(/databases/$(database)/documents/labLocks/$(request.resource.data.labKey)).data.status == 'active'
        && get(/databases/$(database)/documents/labLocks/$(request.resource.data.labKey)).data.expiresAtMs > request.time.toMillis()
      );
      allow delete: if isAdmin();
    }

    match /labLocks/{labKey} {
      allow read: if isActiveUser();
      allow create: if isActiveUser() && request.resource.data.lockedByUid == request.auth.uid;
      allow update: if isAdmin() || (
        isActiveUser() && (
          resource.data.lockedByUid == request.auth.uid
          || resource.data.status != 'active'
          || resource.data.expiresAtMs <= request.time.toMillis()
        )
      );
      allow delete: if isAdmin();
    }

    match /labCompletions/{labKey} {
      allow read: if isActiveUser();
      allow create, update: if isActiveUser();
      allow delete: if isAdmin();
    }

    match /appMeta/{docId} {
      allow read: if isActiveUser();
      allow create, update, delete: if isAdmin();
    }
  }
}
